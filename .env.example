# ── SERVIDOR ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── BASE DE DATOS (Railway te da esto automático) ─────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── AUTENTICACIÓN ─────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=pon_aqui_un_string_muy_largo_y_aleatorio
JWT_EXPIRES_IN=30d

# ── ANTHROPIC (Claude IA) ─────────────────────────────────────────────
# Consíguelo en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── WHATSAPP ───────────────────────────────────────────────────────────
WPP_SESSION_FOLDER=./wpp_sessions
# Delay entre mensajes en ms (5000 = 5 seg, no bajar de 3000)
WPP_SEND_DELAY=5000

# ── FRONTEND ──────────────────────────────────────────────────────────
FRONTEND_URL=https://tu-frontend.vercel.app
